# =============================================================================
# Agenda Clubber — Environment Variables Reference
# =============================================================================
# Copy this file: cp .env.example .env.local
# Never commit .env.local — it is excluded by .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase
# Get these values from: https://supabase.com/dashboard/project/{ref}/settings/api
# -----------------------------------------------------------------------------

# Public project URL (safe to expose in browser bundles)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Publishable/Anon key — limited RLS-restricted access (safe to expose)
# Note: Supabase dashboards may label this NEXT_PUBLIC_SUPABASE_ANON_KEY;
# both names refer to the same key. This project uses the new publishable format.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=<your-publishable-or-anon-key>

# Service Role key — FULL database access. NEVER expose in browser code.
# Used only in server-side code / Edge Functions / admin scripts.
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>

# -----------------------------------------------------------------------------
# Database (Drizzle ORM)
# Postgres connection string — from Supabase > Settings > Database > Connection string
#
# Two URLs are available in Supabase > Settings > Database:
#   - Direct URL   (port 5432)  — required for `npx drizzle-kit push` / migrations
#   - Pooler URL   (port 6543)  — for serverless/edge runtime (next.js api routes, etc.)
#
# For local dev: use the Direct URL to avoid transaction pooler issues with migrations.
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@db.<project-ref>.supabase.co:5432/postgres

# -----------------------------------------------------------------------------
# Application
# Used for building absolute URLs (e.g. auth redirect links)
# Set to http://localhost:3000 for local development
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Sentry — Error monitoring (not active locally — stub only, see src/lib/sentry.ts)
# Uncomment and populate when enabling real Sentry monitoring (planned for DI.4).
# Create a project at https://sentry.io and get the DSN from Settings > DSN
# SENTRY_AUTH_TOKEN and SENTRY_ORG/PROJECT are only needed in CI/CD for source-map uploads.
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_SENTRY_DSN=https://<key>@o<org-id>.ingest.sentry.io/<project-id>
# SENTRY_AUTH_TOKEN=<your-sentry-auth-token>
# SENTRY_ORG=<your-sentry-org-slug>
# SENTRY_PROJECT=<your-sentry-project-slug>

# -----------------------------------------------------------------------------
# Future: Upstash QStash (background jobs / webhooks — Epic 4)
# Uncomment and populate when implementing QStash integration.
# Get credentials from: https://console.upstash.com/qstash
# -----------------------------------------------------------------------------
# QSTASH_TOKEN=<your-qstash-token>
# QSTASH_CURRENT_SIGNING_KEY=<your-current-signing-key>
# QSTASH_NEXT_SIGNING_KEY=<your-next-signing-key>

# -----------------------------------------------------------------------------
# Future: Evolution API (WhatsApp notifications — Epic 4)
# Uncomment and populate when implementing WhatsApp integration.
# -----------------------------------------------------------------------------
# EVOLUTION_API_URL=https://your-evolution-api-instance.example.com
# EVOLUTION_API_KEY=<your-evolution-api-key>
